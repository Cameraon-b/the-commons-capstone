<!DOCTYPE html>
<html>
<head>
  <title>Edit Profile</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="page">
    <div class="topbar">
      <div class="brand">The Commons</div>

      <div class="nav-actions">
        <a class="btn secondary" href="/">Home</a>
        <a class="btn secondary" href="/users/<%= user.user_id %>">Back to Profile</a>
      </div>
    </div>

    <div class="card">
      <h1 class="section-title">Edit Profile</h1>

      <form action="/users/<%= user.user_id %>/edit" method="POST" class="stack">
        <div class="form-group">
          <label for="name">Name</label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            value="<%= user.name %>" 
            required
          />
        </div>

        <div class="form-group">
          <label for="bio">About</label>
          <textarea 
            id="bio" 
            name="bio" 
            rows="5"
          ><%= user.bio || '' %></textarea>
        </div>

        <div class="form-group">
          <label for="zip_code">Zip Code</label>
          <input 
            type="text" 
            id="zip_code" 
            name="zip_code" 
            value="<%= user.zip_code || '' %>" 
          />
        </div>

        <div class="actions">
          <button type="submit" class="btn">Save Changes</button>
          <a class="btn secondary" href="/users/<%= user.user_id %>">Cancel</a>
        </div>

        <div class="form-group">
          <label for="profile_image_url">Profile Image URL</label>
          <input 
            type="text" 
            id="profile_image_url" 
            name="profile_image_url"
            value="<%= user.profile_image_url || '' %>"
            placeholder="Paste an image URL"
          />
        </div>
      </form>
    </div>
  </div>
</body>
</html>