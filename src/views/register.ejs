<!DOCTYPE html>
<html>
<head>
  <title>Register</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

  <div class="topbar">
    <div class="brand">The Commons</div>
    <div class="nav-actions">
      <a class="btn secondary" href="/">Home</a>
    </div>
  </div>

  <div class="register-page">
    <!-- Left Side: Registration Form -->
    <div class="card register-card">
      <h1>Create Account</h1>
      <p class="meta">
        Join The Commons to share tools, offer skills, and connect with your local community.
      </p>

      <form action="/users/register" method="POST">

        <div class="form-group">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required />
        </div>

        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required />
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required />
        </div>

        <div class="form-group">
          <label for="bio">Bio</label>
          <textarea id="bio" name="bio" rows="4" placeholder="Tell your community a little about yourself"></textarea>
        </div>

        <div class="form-group">
          <label for="zip_code">Zip Code</label>
          <input type="text" id="zip_code" name="zip_code" />
        </div>

        <button type="submit" class="btn">Create Account</button>
      </form>

      <br />

      <p>Already have an account?</p>
      <a href="/users/login">Login here</a>
    </div>

    <!-- Right Side: Simple Intro Steps -->
    <div class="card register-info-card">
      <h2>Step Into The Commons</h2>
      <p class="meta">
        The Commons goal is to help people share tools and skills with their community, building networks of mutual aid and trust.
      </p>

      <div class="stack register-steps">
        <div class="step-item">
          <p class="step-title">1. Create an Account</p>
          <p class="meta">Set up your profile to join the network.</p>
        </div>

        <div class="step-item">
          <p class="step-title">2. Build Your Inventory</p>
          <p class="meta">Add tools you own and skills you can share.</p>
        </div>

        <div class="step-item">
          <p class="step-title">3. Create Listings</p>
          <p class="meta">Choose items from your inventory and make them available to others.</p>
        </div>

        <div class="step-item">
          <p class="step-title">4. Share and Collaborate</p>
          <p class="meta">Connect through requests, complete exchanges, and build trust.</p>
        </div>
        <p class="meta" style="margin-top: 10px;">
          Start small. A tool, a skill, or a single listing can be enough to help someone nearby and make a difference in your community.
        </p>
      </div>
    </div>
  </div>

</body>
</html>