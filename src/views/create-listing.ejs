<!DOCTYPE html>
<html>
<head>
  <title>Create Listing</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="page">
    <div class="topbar">
      <div class="brand">The Commons</div>
      <div class="nav-actions">
        <a class="btn secondary" href="/listings">Return to Listings</a>
        <% if (currentUserId) { %>
          <a class="btn secondary" href="/users/<%= currentUserId %>">Profile</a>
        <% } %>
      </div>
    </div>

    <h1 class="section-title">Create Listing</h1>

    <div class="card">
      <form action="/listings" method="POST" class="stack">
        <div class="form-group">
          <label for="type">Type</label>
          <select id="type" name="type" required>
            <option value="tool">Tool</option>
            <option value="skill">Skill</option>
          </select>
        </div>

        <div class="form-group">
          <label for="title">Title</label>
          <input type="text" id="title" name="title" required>
        </div>

        <div class="form-group">
          <label for="description">Description</label>
          <textarea id="description" name="description" required></textarea>
        </div>

        <div class="form-group">
          <label for="category">Category</label>
          <input type="text" id="category" name="category" required>
        </div>

        <div class="form-group">
          <label for="availability">Availability</label>
          <input type="text" id="availability" name="availability" required>
        </div>

        <div class="form-group">
          <label for="zip_code">Zip Code</label>
          <input type="text" id="zip_code" name="zip_code" required>
        </div>

        <div class="actions">
          <button type="submit">Post</button>
        </div>
      </form>
    </div>
  </div>
</body>
</html>