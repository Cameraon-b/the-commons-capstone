<!-- views/create-tool.ejs - This template renders the page for adding a new tool to the user's inventory. The form includes fields for tool name, category, and description. -->

<!DOCTYPE html>
<html>
<head>
  <title>Add Tool</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="page">
    <div class="topbar">
      <div class="brand">The Commons</div>

      <!-- Navigation links for the top bar, buttons for home, listings, and profile. -->
      <div class="nav-actions">
        <a class="btn secondary" href="/">Home</a>
        <a class="btn secondary" href="/listings">Listings</a>
        <a class="btn secondary" href="/users/<%= currentUserId %>">Profile</a>
      </div>
    </div>

    <!-- Section title for the page. -->
    <h1 class="section-title">Add Tool</h1>

    <div class="card">
      <form action="/tools" method="POST" class="stack">
        <div class="form-group">
          <label for="name">Tool Name</label>
          <input type="text" id="name" name="name" required maxlength="100" />
        </div>

        <div class="form-group">
          <label for="category">Category</label>
          <input type="text" id="category" name="category" maxlength="50" />
        </div>

        <div class="form-group">
          <label for="description">Description</label>
          <textarea id="description" name="description" rows="4" maxlength="500"></textarea>
        </div>

        <button class="btn" type="submit">Save Tool</button>
      </form>
    </div>
  </div>
</body>
</html>