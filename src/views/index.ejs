<!-- views/index.ejs - EJS template for the home page of The Commons, a platform for sharing tools and skills. The page includes a hero section with a welcome message and call-to-action buttons, a quote about commoning, and featured categories for browsing listings. It also conditionally displays navigation options based on whether the user is logged in or not. -->

<!DOCTYPE html>
<html>
<head>
  <title>The Commons</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="page">
    <div class="topbar">
      <div class="brand">The Commons</div>

      <div class="nav-actions">
        <% if (currentUserId) { %>
          <form action="/users/logout" method="POST" class="inline-form">
            <a class="btn secondary notif-button" href="/notifications">
              Notifications
              <% const notifCount = typeof notificationCount !== 'undefined' ? notificationCount : 0; %>
              <% if (notifCount > 0) { %>
                <span class="notif-badge"><%= notifCount %></span>
              <% } %>
            </a>
            <button type="submit" class="btn">Logout</button>
          </form>
        <% } else { %>
          <a class="btn secondary" href="/users/login">Login</a>
          <a class="btn secondary" href="/users/register">Sign Up</a>
        <% } %>
      </div>
    </div>

    <div class="card hero-card">
      <h1 class="hero-title">Sharing Tools. Sharing Skills.</h1>
      <p class="hero-subtitle">
        Building networks of mutual aid.
      </p>

      <div class="actions hero-actions">
        <% if (currentUserId) { %>
          <a class="btn" href="/listings">Browse Listings</a>
          <a class="btn secondary" href="/listings/create">Create Listing</a>
        <% } else { %>
          <a class="btn" href="/users/register">Get Started</a>
          <a class="btn secondary" href="/listings">Browse Listings</a>
        <% } %>
      </div>
    </div>

    <% if (currentUserId) { %>
      <div class="card center-card home-section">
        <p class="meta welcome-text">Hello, <strong><%= currentUserName %></strong></p>

        <div class="actions hero-actions">
          <a class="btn" href="/users/<%= currentUserId %>">Your Profile</a>
          <a class="btn secondary" href="/requests">Manage Requests</a>
          <a class="btn secondary" href="/tools/new">+ Add Tool</a>
          <a class="btn secondary" href="/skills/new">+ Add Skill</a>
          <a class="btn secondary" href="/users">Find Users</a>
        </div>
      </div>
    <% } %>

    <div class="card center-card home-section">
      <p class="quote">
        “There is no commons without commoning—the social practices and relationships of
        working together to support one another.” — Peter Linebaugh
      </p>
    </div>

    <div class="card center-card home-section">
      <h2 class="section-subtitle">Featured Categories</h2>

      <div class="actions hero-actions category-actions">
        <a class="btn secondary" href="/listings?category=tech">Tech</a>
        <a class="btn secondary" href="/listings?category=garden">Gardening</a>
        <a class="btn secondary" href="/listings?category=repair">Repairs</a>
        <a class="btn secondary" href="/listings?category=cooking">Cooking</a>
        <a class="btn secondary" href="/listings?category=car">Cars</a>
      </div>
    </div>
  </div>
</body>
</html>