<%# This file defines the EJS template for the "Listings" page, which displays a list of all available listings in the system. Each listing shows its title, description, type, category, availability, zip code, and status. Users can click on a listing title to view its details. The page also includes navigation links to the home page, requests page, and user profile if the user is logged in. Additionally, there is a button to create a new listing. %>

<!DOCTYPE html>
<html>
<head>
  <title>Listings</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="page">
    <div class="topbar">
      <div class="brand">The Commons</div>
      <div class="nav-actions">
        <a class="btn secondary" href="/">Home</a>
        <a class="btn secondary" href="/requests">Requests</a>
        <% if (currentUserId) { %>
          <a class="btn secondary" href="/users/<%= currentUserId %>">Profile</a>
        <% } %>
      </div>
    </div>

    <h1 class="section-title">Listings</h1>

    <div class="actions" style="padding-bottom: 14px;">
      <a class="btn" href="/listings/create">Create New Listing</a>
    </div>

    <div class="card" style="margin-bottom: 20px;">
      <h2>Filters</h2>

      <form method="GET" action="/listings">
        <div class="filter-form">

          <div class="form-group-tight">
            <label for="zip_code">Zip Code</label>
            <input
              type="text"
              id="zip_code"
              name="zip_code"
              value="<%= currentZip %>"
              placeholder="Enter zip code"
            />
          </div>

          <div class="form-group-tight">
            <label for="radius">Distance</label>
            <select id="radius" name="radius">
              <option value="">Any distance</option>
              <option value="5" <%= currentRadius == '5' ? 'selected' : '' %>>5 miles</option>
              <option value="10" <%= currentRadius == '10' ? 'selected' : '' %>>10 miles</option>
              <option value="25" <%= currentRadius == '25' ? 'selected' : '' %>>25 miles</option>
            </select>
          </div>

          <div class="form-group-tight">
            <label for="category">Category</label>
            <input
              type="text"
              id="category"
              name="category"
              value="<%= currentCategory %>"
              placeholder="e.g. gardening, tech"
            />
          </div>

          <div class="form-group-tight">
            <label for="type">Type</label>
            <select id="type" name="type">
              <option value="">Any type</option>
              <option value="tool" <%= currentType == 'tool' ? 'selected' : '' %>>Tool</option>
              <option value="skill" <%= currentType == 'skill' ? 'selected' : '' %>>Skill</option>
            </select>
          </div>
        </div>

        <div class="filter-actions" style="margin-top: 14px;">
          <button type="submit" class="btn">Apply Filter</button>
          <a href="/listings" class="btn secondary">Clear</a>
        </div>
      </form>
    </div>

    <div class="stack">
      <% listings.forEach(listing => { %>
        <div class="card">
          <div class="listing-card-title">
            <a href="/listings/<%= listing.listing_id %>"><%= listing.title %></a>
          </div>

          <p><%= listing.description %></p>
          <p class="meta"><strong>Posted by:</strong> <%= listing.name %></p>
          <p class="meta">
            Type: <%= listing.type %> |
            Category: <%= listing.category %> |
            Availability: <%= listing.availability %> |
            Status: <%= listing.status %>
          </p>

          <% if (listing.distance !== undefined) { %>
            <p class="meta"><strong>Distance:</strong> <%= listing.distance %> miles</p>
          <% } else { %>
            <p class="meta"><strong>Zip:</strong> <%= listing.zip_code %></p>
          <% } %>
        </div>
      <% }) %>
    </div>
  </div>
</body>
</html>