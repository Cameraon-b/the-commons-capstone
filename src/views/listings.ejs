<%# This file defines the EJS template for the "Listings" page, which displays a list of all available listings in the system. Each listing shows its title, description, type, category, availability, zip code, and status. Users can click on a listing title to view its details. The page also includes navigation links to the home page, requests page, and user profile if the user is logged in. Additionally, there is a button to create a new listing. %>

<!DOCTYPE html>
<html>
<head>
  <title>Listings</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="page">
    <div class="topbar">
      <div class="brand">The Commons</div>
      <div class="nav-actions">
        <a class="btn secondary" href="/">Home</a>
        <a class="btn secondary" href="/requests">Requests</a>
        <% if (currentUserId) { %>
          <a class="btn secondary" href="/users/<%= currentUserId %>">Profile</a>
        <% } %>
      </div>
    </div>

    <h1 class="section-title">Listings</h1>

    <div class="actions">
      <a class="btn" href="/listings/create">Create New Listing</a>
    </div>

    <div class="stack">
      <% listings.forEach(listing => { %>
        <div class="card">
          <div class="listing-card-title">
            <a href="/listings/<%= listing.listing_id %>"><%= listing.title %></a>
          </div>

          <p><%= listing.description %></p>
          <p class="meta"><strong>Posted by:</strong> <%= listing.name %></p>
          <p class="meta">
            Type: <%= listing.type %> |
            Category: <%= listing.category %> |
            Availability: <%= listing.availability %> |
            Zip: <%= listing.zip_code %> |
            Status: <%= listing.status %>
          </p>
        </div>
      <% }) %>
    </div>
  </div>
</body>
</html>