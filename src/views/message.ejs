<!-- views/message.ejs - EJS template for a generic message page, which can be used to display various messages to the user along with a call-to-action button. The page includes a title, a message, and an action button that redirects the user to a specified URL. The top navigation bar includes links to the home page and listings page. -->

<!DOCTYPE html>
<html>
<head>
  <title>Commons</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="page">
    <div class="topbar">
      <div class="brand">The Commons</div>
      <div class="nav-actions">
        <a class="btn secondary" href="/">Home</a>
        <a class="btn secondary" href="/listings">Browse Listings</a>
      </div>
    </div>

    <div class="card">
      <h1 class="section-title"><%= title %></h1>
      <p><%= message %></p>

      <div class="actions">
        <a class="btn" href="<%= actionHref %>"><%= actionText %></a>
      </div>
    </div>
  </div>
</body>
</html>