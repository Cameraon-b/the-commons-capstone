<!-- views/edit-listing.ejs - This template renders the page for editing an existing listing. The form is pre-populated with the current listing details, allowing users to update the title, description, category, availability, zip code, status, and image URL. The page also includes -->

<!DOCTYPE html>
</html>
<head>
  <title>Edit Listing</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="page">
    <div class="topbar">
      <div class="brand">The Commons</div>

      <!-- Navigation links for the top bar, buttons for home, listings, and profile. -->
      <div class="nav-actions">
        <a class="btn secondary" href="/">Home</a>
        <a class="btn secondary" href="/listings">Listings</a>
        <a class="btn secondary" href="/users/<%= currentUserId %>">Profile</a>
      </div>
    </div>

    <!-- Section title for the page. -->
    <h1 class="section-title">Edit Listing</h1>

    <!-- Form for editing an existing listing. -->
    <div class="card">
      <form action="/listings/<%= listing.listing_id %>/edit" method="POST" class="stack">
        <div class="form-group">
          <label for="title">Title</label>
          <input 
          type="text" 
          id="title" 
          name="title" 
          value="<%= listing.title %>" 
          required
          maxlength="75"
          >
        </div>

        <div class="form-group">
          <label for="description">Description</label>
          <textarea 
          id="description" 
          name="description" 
          rows="4"
          maxlength="500"
          ><%= listing.description %></textarea>
        </div>

        <div class="form-group">
          <label for="category">Category</label>
          <input 
          type="text" 
          id="category" 
          name="category" 
          value="<%= listing.category %>" 
          required
          maxlength="30"
        </div>

        <div class="form-group">
          <label for="availability">Availability</label>
          <input 
          type="text" 
          id="availability" 
          name="availability" 
          value="<%= listing.availability || '' %>"
          maxlength="100"
          >
        </div>

        <div class="form-group">
          <label for="zip_code">Zip Code</label>
          <input 
          type="text" 
          id="zip_code" 
          name="zip_code" 
          value="<%= listing.zip_code %>" 
          required
          maxlength="5"
        >
        </div>

        <div class="form-group">
          <label for ="status">Status</label>
          <select id="status" name="status">
            <option value="available" <%= listing.status === 'available' ? 'selected' : '' %>>Available</option>
            <option value="in_use" <%= listing.status === 'in_use' ? 'selected' : '' %>>In Use</option>
            <option value="unavailable" <%= listing.status === 'unavailable' ? 'selected' : '' %>>Unavailable</option>
          </select>
        </div>

        <div class="form-group">
          <label for="image_url">Image URL (optional)</label>
          <input
            type="text"
            id="image_url"
            name="image_url"
            value="<%= listing.image_url || '' %>"
            placeholder="Paste a direct image link"
          />
        </div>

        <button class="btn" type="submit">Update Listing</button>
      </form>
    </div>
  </div>
</body>
</html>