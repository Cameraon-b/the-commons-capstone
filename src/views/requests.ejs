<!-- views/requests.ejs - EJS template for the "Manage Requests" page, which allows users to view and manage their incoming and outgoing requests. The page is divided into three sections: Incoming Requests, Sent Requests, and Request History. Users can accept, decline, or mark requests as complete. The top navigation bar includes links to the home page, listings page, and user profile if the user is logged in. -->

<!DOCTYPE html>
<html>
<head>
  <title>Manage Requests</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="page">
    <div class="topbar">
      <div class="brand">The Commons</div>

      <div class="nav-actions">
        <a class="btn secondary" href="/">Home</a>
        <a class="btn secondary" href="/listings">Return to Listings</a>
        <% if (currentUserId) { %>
          <a class="btn secondary" href="/users/<%= currentUserId %>">Profile</a>
        <% } %>
      </div>
    </div>

    <h1 class="section-title">Requests</h1>
    <p class="meta">Logged in as: <strong><%= currentUserName %></strong></p>

    <div class="card-grid three">
      <!-- Incoming Requests -->
      <div>
        <h2>Incoming</h2>

        <% const activeIncoming = incomingRequests.filter(request => request.status === 'pending' || request.status === 'accepted'); %>

        <% if (incomingRequests.length === 0) { %>
          <div class="card">
            <p>No incoming requests.</p>
          </div>
        <% } else { %>
          <div class="stack scroll-section">
            <% incomingRequests.forEach(request => { %>
              <div class="card">
                <h3>Request from: <%= request.requester_name %></h3>
                <p><strong>Requested:</strong> <%= request.listing_title %></p>
                <p class="meta"><strong>Created:</strong> <%= request.created_at %></p>
                <p><strong>Message:</strong> <%= request.request_message %></p>
                <p><strong>Contact:</strong> <%= request.contact_method %> - <%= request.contact_value %></p>
                <p><strong>Status:</strong> <%= request.status %></p>

                <% if (request.status === 'pending') { %>
                  <div class="actions">
                    <form action="/requests/<%= request.request_id %>/accept" method="POST" class="inline-form">
                      <button type="submit" class="btn secondary">Accept</button>
                    </form>

                    <form action="/requests/<%= request.request_id %>/decline" method="POST" class="inline-form">
                      <button type="submit">Decline</button>
                    </form>
                  </div>
                <% } %>

                <% if (request.status === 'accepted') { %>
                  <div class="actions">
                    <form action="/requests/<%= request.request_id %>/complete" method="POST" class="inline-form">
                      <button type="submit" class="btn secondary">Mark Complete</button>
                    </form>
                  </div>
                <% } %>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>

      <!-- Outgoing Requests -->
      <div>
        <h2>Sent</h2>

        <% if (outgoingRequests.length === 0) { %>
          <div class="card">
            <p>No outgoing requests.</p>
          </div>
        <% } else { %>
          <div class="stack scroll-section">
            <% outgoingRequests.forEach(request => { %>
              <% if (request.status === 'pending' || request.status === 'accepted') { %>
                <div class="card">
                  <h3>Requested <%= request.listing_title %> from <%= request.owner_name %></h3>
                  <p class="meta"><strong>Created:</strong> <%= request.created_at %></p>
                  <p><strong>Status:</strong> <%= request.status %></p>
                  <p><strong>Message:</strong> <%= request.request_message %></p>
                </div>
              <% } %>
            <% }) %>
          </div>
        <% } %>
      </div>

      <!-- History -->
      <div>
        <h2>History</h2>

        <% if (historyRequests.length === 0) { %>
          <div class="card">
            <p>No request history yet.</p>
          </div>
        <% } else { %>
          <div class="stack scroll-section">
            <% historyRequests.forEach(request => { %>
              <div class="card">
                <h3>
                  <% if (request.listing_title) { %>
                    <%= request.listing_title %>
                  <% } else { %>
                    Request
                  <% } %>
                </h3>

                <% if (request.requester_name) { %>
                  <p><strong>Requester:</strong> <%= request.requester_name %></p>
                <% } %>

                <% if (request.owner_name) { %>
                  <p><strong>Owner:</strong> <%= request.owner_name %></p>
                <% } %>

                <p class="meta"><strong>Created:</strong> <%= request.created_at %></p>
                <p><strong>Status:</strong> <%= request.status %></p>

                <% if (request.status === 'completed') { %>
                  <div class="actions">
                    <a href="/reviews/<%= request.request_id %>/new" class="btn secondary">Leave Review</a>
                  </div>
                <% } %>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>