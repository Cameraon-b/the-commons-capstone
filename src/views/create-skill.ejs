<!-- views/create-skill.ejs - EJS template for the "Add Skill" page, allowing users to add a new skill to their profile. The page includes a form for entering skill details such as name, category, and description. It also provides navigation links to the home page, listings page, and user profile. -->

<!DOCTYPE html>
<html>
<head>
  <title>Add Skill</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="page">
    <div class="topbar">
      <div class="brand">The Commons</div>

      <div class="nav-actions">
        <a class="btn secondary" href="/">Home</a>
        <a class="btn secondary" href="/listings">Listings</a>
        <a class="btn secondary" href="/users/<%= currentUserId %>">Profile</a>
      </div>
    </div>

    <h1 class="section-title">Add Skill</h1>

    <div class="card">
      <form action="/skills" method="POST" class="stack">
        <div class="form-group">
          <label for="name">Skill Name</label>
          <input type="text" id="name" name="name" required>
        </div>

        <div class="form-group">
          <label for="category">Category</label>
          <input type="text" id="category" name="category">
        </div>

        <div class="form-group">
          <label for="description">Description</label>
          <textarea id="description" name="description" rows="4"></textarea>
        </div>

        <button class="btn" type="submit">Save Skill</button>
      </form>
    </div>
  </div>
</body>
</html>