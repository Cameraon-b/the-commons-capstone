<!-- views/leave-review.ejs - This template renders the page for leaving a review after an exchange has been completed. The form includes a dropdown for selecting a rating from 1 to 5 and a textarea for writing a comment. The title of the page dynamically includes the name of the user being reviewed. -->

<!DOCTYPE html>
<html>
<head>
  <title>Review The Exchange</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="page">
    <div class="topbar">
      <div class="brand">The Commons</div>

      <!-- Navigation links for the top bar, buttons for home, return to requests, and profile if the user is logged in. -->
      <div class="nav-actions">
        <a class="btn secondary" href="/">Home</a>
        <a class="btn secondary" href="/requests">Return to Requests</a>
        <% if (currentUserId) { %>
          <a class="btn secondary" href="/users/<%= currentUserId %>">Profile</a>
        <% } %>
      </div>
    </div>

    <!-- Form for leaving a review, including a dropdown for rating and a textarea for comments. -->
    <h1 class="section-title">Leave a Review for <%= reviewedUser.name %></h1>

    <div class="card">
      <form action="/reviews/<%= request.request_id %>" method="POST" class="stack">
        <div class="form-group">
          <label for="rating">Rating</label>
          <select id="rating" name="rating" required>
            <option value="5">5 - Excellent</option>
            <option value="4">4 - Good</option>
            <option value="3">3 - Fine</option>
            <option value="2">2 - Poor</option>
            <option value="1">1 - Bad</option>
          </select>
        </div>

        <div class="form-group">
          <label for="comment">Comment</label>
          <textarea id="comment" name="comment" rows="4" required maxlength="500"></textarea>
        </div>

        <div class="actions">
          <button type="submit" class="btn">Submit Review</button>
        </div>
      </form>
    </div>
  </div>
</body>
</html>